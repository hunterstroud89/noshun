        {
            "id": "blk_mnl7p4tic1hcm",
            "type": "p",
            "content": "This page shows off <strong>every block type</strong> the editor supports. Use it as a reference or a playground. Try <em>italic</em>, <u>underline</u>, <s>strikethrough</s>, <code>inline code</code>, and <mark style=\"background: rgba(255, 212, 0, 0.4); padding: 0 2px; border-radius: 2px;\">highlighted text</mark>.",
            "checked": false,
            "open": false,
            "indent": 0
        },
        {
            "id": "blk_mnl7p4ti3g6al",
            "type": "h2",
            "content": "Heading 2 — A Section",
            "checked": false,
            "open": false,
            "indent": 0
        },
        {
            "id": "blk_mnl7p4tik9non",
            "type": "p",
            "content": "Paragraphs are the default block. Type <code>/</code> at the start of any block to switch types. You can also use markdown shortcuts like <code># </code> for headings or <code>- </code> for bullets.",
            "checked": false,
            "open": false,
            "indent": 0
        },
